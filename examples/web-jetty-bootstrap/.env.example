# Copy this file to .env for local use only.
# Never commit .env — it is listed in .gitignore.

# Option 1 (recommended): explicit Copilot token
COPILOT_GITHUB_TOKEN=gho_your_token_here

# Option 2: GitHub CLI compatible token
# GH_TOKEN=gho_your_token_here

# Option 3: generic GitHub token
# GITHUB_TOKEN=gho_your_token_here
